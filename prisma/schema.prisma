// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String      @unique
  emailVerified        DateTime?
  image                String?
  calendarId           String?
  // Google access token expiry (from OAuth account metadata)
  googleTokenExpiresAt DateTime?
  accounts             Account[]
  sessions             Session[]
  workplaces           Workplace[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum WorkplaceType {
  GENERAL
  CRAM_SCHOOL
}

enum TimetableType {
  NORMAL
  INTENSIVE
}

enum ShiftType {
  NORMAL
  LESSON
  OTHER
}

enum HolidayType {
  NONE
  WEEKEND
  HOLIDAY
  WEEKEND_HOLIDAY
}

model Workplace {
  id           String        @id @default(cuid())
  userId       String
  name         String
  type         WorkplaceType
  color        String
  createdAt    DateTime      @default(now())
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payrollRules PayrollRule[]
  timetables   Timetable[]
  shifts       Shift[]

  @@index([userId])
}

model PayrollRule {
  id                     String      @id @default(cuid())
  workplaceId            String
  startDate              DateTime    @db.Date
  endDate                DateTime?   @db.Date
  baseHourlyWage         Decimal     @db.Decimal(10, 2)
  perLessonWage          Decimal?    @db.Decimal(10, 2)
  holidayHourlyWage      Decimal?    @db.Decimal(10, 2)
  nightMultiplier        Decimal     @db.Decimal(4, 2)
  overtimeMultiplier     Decimal     @db.Decimal(4, 2)
  nightStart             DateTime    @db.Time(0)
  nightEnd               DateTime    @db.Time(0)
  dailyOvertimeThreshold Decimal     @db.Decimal(5, 2)
  holidayType            HolidayType
  workplace              Workplace   @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  @@index([workplaceId])
  @@index([workplaceId, startDate, endDate])
}

model Timetable {
  id          String        @id @default(cuid())
  workplaceId String
  type        TimetableType
  period      Int
  startTime   DateTime      @db.Time(0)
  endTime     DateTime      @db.Time(0)
  workplace   Workplace     @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  @@unique([workplaceId, type, period])
  @@index([workplaceId])
}

model Shift {
  id               String            @id @default(cuid())
  workplaceId      String
  date             DateTime          @db.Date
  startTime        DateTime          @db.Time(0)
  endTime          DateTime          @db.Time(0)
  breakMinutes     Int               @default(0)
  shiftType        ShiftType
  googleEventId    String?
  googleSyncStatus String            @default("PENDING")
  googleSyncError  String?
  googleSyncedAt   DateTime?
  createdAt        DateTime          @default(now())
  workplace        Workplace         @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  lessonRange      ShiftLessonRange?

  @@index([workplaceId, date])
}

model ShiftLessonRange {
  id          String @id @default(cuid())
  shiftId     String @unique
  startPeriod Int
  endPeriod   Int
  shift       Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}
