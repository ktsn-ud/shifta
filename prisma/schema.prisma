// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../lib/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(cuid())
  name                 String?
  email                String      @unique
  emailVerified        DateTime?
  image                String?
  calendarId           String?
  // Google access token expiry (from OAuth account metadata)
  googleTokenExpiresAt DateTime?
  accounts             Account[]
  sessions             Session[]
  workplaces           Workplace[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum WorkplaceType {
  GENERAL
  CRAM_SCHOOL
}

enum ClosingDayType {
  DAY_OF_MONTH
  END_OF_MONTH
}

enum ShiftType {
  NORMAL
  LESSON
}

enum HolidayType {
  NONE
  WEEKEND
  HOLIDAY
  WEEKEND_HOLIDAY
}

model Workplace {
  id             String         @id @default(cuid())
  userId         String
  name           String
  type           WorkplaceType
  color          String
  closingDayType ClosingDayType @default(END_OF_MONTH)
  closingDay     Int?
  payday         Int            @default(25)
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  payrollRules   PayrollRule[]
  timetableSets  TimetableSet[]
  shifts         Shift[]

  @@index([userId])
}

model PayrollRule {
  id                     String      @id @default(cuid())
  workplaceId            String
  startDate              DateTime    @db.Date
  endDate                DateTime?   @db.Date
  baseHourlyWage         Decimal     @db.Decimal(10, 2)
  holidayAllowanceHourly Decimal     @default(0) @db.Decimal(10, 2)
  nightPremiumRate       Decimal     @default(0.25) @db.Decimal(4, 2)
  overtimePremiumRate    Decimal     @default(0.25) @db.Decimal(4, 2)
  dailyOvertimeThreshold Decimal     @db.Decimal(5, 2)
  holidayType            HolidayType
  workplace              Workplace   @relation(fields: [workplaceId], references: [id], onDelete: Cascade)

  @@index([workplaceId])
  @@index([workplaceId, startDate, endDate])
}

model TimetableSet {
  id               String            @id @default(cuid())
  workplaceId      String
  name             String
  sortOrder        Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  workplace        Workplace         @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  timetables       Timetable[]
  shiftLessonRanges ShiftLessonRange[]

  @@index([workplaceId])
  @@unique([workplaceId, name])
}

model Timetable {
  id             String       @id @default(cuid())
  timetableSetId String
  period         Int
  startTime      DateTime     @db.Time(0)
  endTime        DateTime     @db.Time(0)
  timetableSet   TimetableSet @relation(fields: [timetableSetId], references: [id], onDelete: Cascade)

  @@unique([timetableSetId, period])
  @@index([timetableSetId])
}

model Shift {
  id               String            @id @default(cuid())
  workplaceId      String
  date             DateTime          @db.Date
  startTime        DateTime          @db.Time(0)
  endTime          DateTime          @db.Time(0)
  breakMinutes     Int               @default(0)
  isConfirmed      Boolean           @default(false)
  shiftType        ShiftType
  googleEventId    String?
  googleSyncStatus String            @default("PENDING")
  googleSyncError  String?
  googleSyncedAt   DateTime?
  createdAt        DateTime          @default(now())
  workplace        Workplace         @relation(fields: [workplaceId], references: [id], onDelete: Cascade)
  lessonRange      ShiftLessonRange?

  @@index([workplaceId, date])
}

model ShiftLessonRange {
  id             String       @id @default(cuid())
  shiftId         String       @unique
  timetableSetId  String
  startPeriod     Int
  endPeriod       Int
  shift           Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  timetableSet    TimetableSet @relation(fields: [timetableSetId], references: [id], onDelete: Restrict)

  @@index([timetableSetId])
}
